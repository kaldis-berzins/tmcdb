// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Institution {
  CD
  BoA
  GC
  ECJ
}

model Proceeding {
  id            String   @id @default(uuid())

  // Relations to Decision (optional, since not every case reaches all levels)
  cdDecisionId  String? 
  boaDecisionId String?
  gcDecisionId  String?
  ecjDecisionId String?

  cdDecision    Decision? @relation("CDDecision", fields: [cdDecisionId], references: [id])
  boaDecision   Decision? @relation("BoADecision", fields: [boaDecisionId], references: [id])
  gcDecision    Decision? @relation("GCDecision", fields: [gcDecisionId], references: [id])
  ecjDecision   Decision? @relation("ECJDecision", fields: [ecjDecisionId], references: [id])

  // Trademark relation
  trademarkNumber Int
  trademark       Trademark @relation(fields: [trademarkNumber], references: [number])

  createdAt DateTime @default(now())
}

model Trademark {
  // From EUIPO → NOT autogenerated
  number Int    @id
  type   String
  name   String

  proceedings Proceeding[]
}

model Decision {
  // From EUIPO → NOT autogenerated
  id          String      @id
  institution Institution
  outcome     String

  // Generated (not from EUIPO)
  ingestDate  DateTime    @default(now())
  rawText     String

  // Reverse relations
  cdProceedings  Proceeding[] @relation("CDDecision")
  boaProceedings Proceeding[] @relation("BoADecision")
  gcProceedings  Proceeding[] @relation("GCDecision")
  ecjProceedings Proceeding[] @relation("ECJDecision")

  factors Factor[]
}

model Factor {
  id         String   @id @default(uuid())

  decisionId String
  decision   Decision @relation(fields: [decisionId], references: [id])

  name   String
  source String
}