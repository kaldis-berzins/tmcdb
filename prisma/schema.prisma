generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Institution {
  CD
  BOA
  GC
  ECJ
  OTHER
}

enum SourceType {
  EUIPO
  IUROPA
  MANUAL
  OTHER
}

enum LinkType {
  APPEAL
  RELATED
}

enum FactorValue {
  YES
  NO
  UNCLEAR
  NOT_ADDRESSED
}

model Decision {
  id              String   @id @default(cuid())
  sourceKey       String  @unique
  institution     Institution
  source          SourceType
  caseNumber      String
  date            DateTime?
  url             String?
  decisionType    String?
  outcome         String?

  trademarkNumber String?
  trademarkName   String?

  textLanguage    String?
  textUrl         String?
  text            String?  @db.Text

  provisions      DecisionProvision[]
  factors         DecisionFactor[]
  factorsProcessed  Boolean    @default(false)

  outgoingLinks   DecisionLink[] @relation("FromDecision")
  incomingLinks   DecisionLink[] @relation("ToDecision")

  citationsMade     Citation[] @relation("CitingDecision")
  citationsReceived Citation[] @relation("CitedDecision")
  citationsProcessed  Boolean    @default(false)

  @@index([caseNumber])
  @@index([date])
  @@index([trademarkNumber])
}

model Provision {
  id       String @id @default(cuid())
  code     String
  article  String
  label    String @unique

  decisions DecisionProvision[]

  @@unique([code, article])
}

model DecisionProvision {
  decisionId  String
  provisionId String

  decision    Decision  @relation(fields: [decisionId], references: [id], onDelete: Cascade)
  provision   Provision @relation(fields: [provisionId], references: [id], onDelete: Cascade)

  @@id([decisionId, provisionId])
  @@index([provisionId])
}

model Factor {
  id       String @id @default(cuid())
  key      String @unique
  label    String

  findings DecisionFactor[]
}

model DecisionFactor {
  decisionId String
  factorId   String
  value      FactorValue
  evidence   String? @db.Text

  decision   Decision @relation(fields: [decisionId], references: [id], onDelete: Cascade)
  factor     Factor   @relation(fields: [factorId], references: [id], onDelete: Cascade)

  @@id([decisionId, factorId])
  @@index([factorId, value])
}

model DecisionLink {
  id                String   @id @default(cuid())
  fromDecisionId    String
  toDecisionId      String?
  externalReference String?
  linkType          LinkType

  fromDecision      Decision @relation("FromDecision", fields: [fromDecisionId], references: [id], onDelete: Cascade)
  toDecision        Decision? @relation("ToDecision", fields: [toDecisionId], references: [id], onDelete: SetNull)

  @@index([fromDecisionId, linkType])
  @@index([toDecisionId, linkType])
}

model Citation {
  id              String   @id @default(cuid())
  citingDecisionId String
  citedDecisionId  String?
  citedReference   String?
  text             String   @db.Text

  citingDecision   Decision @relation("CitingDecision", fields: [citingDecisionId], references: [id], onDelete: Cascade)
  citedDecision    Decision? @relation("CitedDecision", fields: [citedDecisionId], references: [id], onDelete: SetNull)

  @@index([citingDecisionId])
  @@index([citedDecisionId])
}